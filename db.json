plugins/gitment.css","hash":"541ff18d7f3542b5663dc6aad06d43e135332b71","modified":1693300577135},{"_id":"themes/vexo/source/fonts/SourceSansPro.ttf","hash":"1e9f0372c269da205fdbac8cf27cb9cf59f6ad45","modified":1693300577136},{"_id":"themes/vexo/source/js/gitment.js","hash":"376446d9c5930576016f97dd63e5e6616c94d8d4","modified":1693300577137}],"Category":[{"name":"blog","_id":"cllw44n2f00045v1dct0f8b68"}],"Data":[],"Page":[{"title":"About","layout":"about","_content":"","source":"about/index.md","raw":"---\ntitle: About\nlayout: about\n---","date":"2023-08-29T09:19:21.100Z","updated":"2023-08-29T09:16:17.120Z","path":"about/index.html","comments":1,"_id":"cllw44n2600005v1ddij425r7","content":"","site":{"data":{}},"excerpt":"","more":""},{"title":"Series","layout":"series","_content":"","source":"series/index.md","raw":"---\ntitle: Series\nlayout: series\n---\n","date":"2023-08-29T09:19:21.188Z","updated":"2023-08-29T09:16:17.121Z","path":"series/index.html","comments":1,"_id":"cllw44n2d00025v1d91fxhe4t","content":"","site":{"data":{}},"excerpt":"","more":""},{"title":"Project","layout":"project","_content":"","source":"project/index.md","raw":"---\ntitle: Project\nlayout: project\n---\n","date":"2023-08-29T09:19:21.140Z","updated":"2023-08-29T09:16:17.121Z","path":"project/index.html","comments":1,"_id":"cllw44n2h00065v1de9v22i0z","content":"","site":{"data":{}},"excerpt":"","more":""},{"title":"Tags","layout":"tags","_content":"","source":"tags/index.md","raw":"---\ntitle: Tags\nlayout: tags\n---\n","date":"2023-08-29T09:19:21.237Z","updated":"2023-08-29T09:16:17.122Z","path":"tags/index.html","comments":1,"_id":"cllw44n2i00075v1ddc62ddug","content":"","site":{"data":{}},"excerpt":"","more":""}],"Post":[{"title":"About me","_content":"\n# 勵志活著與眾不同的小菜雞\n\n### 小小的自我介紹:\n逸凡是一個來自台中高工資訊科二年級的學生,對於資訊安全有不小的興趣,雖然在過程中有些迷茫,但還是努力的學習\n\n\n## SCHOOL:\n#### TCIVS CSE 2A\n\n\n# 經歷：\n#### 文華高中電研社社課講師 \n#### SCAICT112屆資訊組\n#### 台中高工網路安全選手\n#### 2023 AIS3 CLUB 代表中電會 \n\n\n# 證照：\n#### I