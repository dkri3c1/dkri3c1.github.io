height="984"
srcset="https://dkri3c1.github.io/p/cyberdefenders-openwire/image-2_hub51860f904b34b0473388cba05c98eda_62522_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-openwire/image-2_hub51860f904b34b0473388cba05c98eda_62522_1024x0_resize_box_3.png 1024w"
