height="550"
srcset="https://dkri3c1.github.io/p/cyberdefenders-openwire/image-14_hu3ae56e19324c2e805cca20e5097118ca_39356_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-openwire/image-14_hu3ae56e19324c2e805cca20e5097118ca_39356_1024x0_resize_box_3.png 1024w"
