height="1024"
srcset="https://dkri3c1.github.io/p/cyberdefenders-webstrike/image-2_hu979aadb5198c31a12856a52f1d263e4e_22391_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-webstrike/image-2_hu979aadb5198c31a12856a52f1d263e4e_22391_1024x0_resize_box_3.png 1024w"
