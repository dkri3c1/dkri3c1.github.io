width="741"
height="616"
srcset="https://dkri3c1.github.io/p/cyberdefenders-webstrike/image-1_hu2da9772ce797847c8e5a92fcbc02e00b_10602_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-webstrike/image-1_hu2da9772ce797847c8e5a92fcbc02e00b_10602_1024x0_resize_box_3.png 1024w"
loading="lazy"
