width="956"
height="658"
srcset="https://dkri3c1.github.io/p/cyberdefenders-openwire/image_hu141b1eadb1ecde95809b59d472552758_74883_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-openwire/image_hu141b1eadb1ecde95809b59d472552758_74883_1024x0_resize_box_3.png 1024w"
