height="447"
srcset="https://dkri3c1.github.io/p/cyberdefenders-openwire/image-8_hub395ac3042afa18411e7d7dd9742aaf9_45426_480x0_resize_box_3.png 480w, https://dkri3c1.github.io/p/cyberdefenders-openwire/image-8_hub395ac3042afa18411e7d7dd9742aaf9_45426_1024x0_resize_box_3.png 1024w"
